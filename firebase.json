{
  "hosting": {
    "target": "eurappia",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "README.md",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/index.html",
        "destination": "https://eurappia.com/",
        "type": 301
      }
    ]
  }
}